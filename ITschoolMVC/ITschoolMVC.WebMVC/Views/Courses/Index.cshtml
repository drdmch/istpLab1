@model IEnumerable<ITschoolMVC.Domain.Entities.Course>

@{
    ViewData["Title"] = "Наші курси";
}

<div class="container mt-5">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-start mb-5">
        <div>
            <h1 class="display-4 fw-bold text-gradient mb-0">Доступні курси</h1>
            <p class="text-muted">Обирай свій шлях у світі IT</p>
        </div>
        
        <div class="d-flex flex-column gap-2 align-items-end">
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill shadow-sm px-4 w-100">
                <i class="bi bi-plus-lg me-2"></i>Додати курс
            </a>
            <a asp-action="ExportPricesXml" class="btn btn-outline-success rounded-pill shadow-sm px-4 w-100">
                <i class="bi bi-filetype-xml me-2"></i>Експорт XML
            </a>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-6">
            <form asp-action="Index" method="get">
                <div class="input-group ultra-shadow rounded-pill overflow-hidden bg-white p-1">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                           class="form-control border-0 px-4 bg-transparent" 
                           placeholder="Пошук курсу за назвою..." />
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="bi bi-search"></i>
                    </button>
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-link text-muted px-3">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted opacity-25 mb-3"><i class="bi bi-search"></i></div>
            <h3 class="text-secondary fw-light">Нічого не знайдено</h3>
            <p class="text-muted">За запитом "@ViewData["CurrentFilter"]" результатів немає.</p>
            <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">Скинути фільтри</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm hover-card rounded-4 overflow-hidden">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 fw-bold">
                                    $@item.Price
                                </span>
                            </div>
                            <h5 class="card-title fw-bold mb-3">@item.Title</h5>
                            <p class="card-text text-muted small" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Description
                            </p>

                            <div class="mt-4">
                                <form asp-action="Enroll" method="post">
                                    <input type="hidden" name="courseId" value="@item.Id" />
                                    <button type="submit" class="btn btn-success w-100 rounded-pill shadow-sm fw-bold py-2">
                                        <i class="bi bi-mortarboard-fill me-2"></i>Записатися на курс
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <hr class="mt-0 mb-3 opacity-10">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small italic">
                                    <i class="bi bi-info-circle me-1"></i> Доступ після запису
                                </span>
                                
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-link btn-sm text-decoration-none text-muted p-1" title="Редагувати">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-link btn-sm text-decoration-none text-danger p-1" title="Видалити">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .text-gradient {
        background: linear-gradient(90deg, #0d6efd, #6610f2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .ultra-shadow {
        box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
    }
    .hover-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
    }
    .hover-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.12) !important;
    }
    .italic {
        font-style: italic;
    }
</style>