@{
    ViewData["Title"] = "Про школу";
}

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h2 class="mb-4 fw-bold text-gradient">Про школу ITschool 🎓</h2>
            <p class="lead">Ця школа заснована студенткою факультету компʼютерних наук та кібернетики КНУ для того, щоб зробити навчання програмуванню доступним та зрозумілим.</p>
            
            <h4 class="mt-4 fw-bold">Чому обирають нас?</h4>
            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item bg-transparent border-0 ps-0">
                    <i class="bi bi-check2-circle text-primary me-2"></i>Тільки актуальні технології (.NET 9, PostgreSQL)
                </li>
                <li class="list-group-item bg-transparent border-0 ps-0">
                    <i class="bi bi-check2-circle text-primary me-2"></i>Досвідчені ментори з провідних IT-компаній
                </li>
                <li class="list-group-item bg-transparent border-0 ps-0">
                    <i class="bi bi-check2-circle text-primary me-2"></i>Гнучкий графік навчання
                </li>
            </ul>

            <div class="p-4 bg-dark text-white rounded-4 shadow-sm mb-4">
                <h5 class="text-center fw-bold">Наша місія</h5>
                <p class="text-center mb-0 opacity-75">Створити найкраще середовище для розвитку українських талантів у сфері високих технологій.</p>
            </div>
        </div>

        @* діаграма*@
        <div class="col-md-6">
            <div class="card border-0 ultra-shadow rounded-4 bg-white p-4 mb-4">
                <h5 class="fw-bold mb-3 text-center">Наші ТОП-3 курси</h5>
                <div id="topCoursesChart" style="width: 100%; height: 250px;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', {'packages':['corechart']});
        google.charts.setOnLoadCallback(drawTopChart);

        function drawTopChart() {
            fetch('/api/charts/topCourses')
                .then(response => response.json())
                .then(data => {
                    const dataTable = new google.visualization.DataTable();
                    dataTable.addColumn('string', 'Курс');
                    dataTable.addColumn('number', 'Студенти');

                    data.forEach(item => {
                        dataTable.addRow([item.title, item.count]);
                    });

                    const options = {
                        fontName: 'Inter',
                        fontSize: 12,
                        colors: ['#0d6efd'],
                        legend: { position: 'none' },
                        chartArea: { width: '85%', height: '75%' },
                        vAxis: { minValue: 0, gridlines: { color: '#f0f0f0' } },
                        hAxis: { slantedText: false },
                        animation: { startup: true, duration: 1000, easing: 'out' },
                        backgroundColor: 'transparent'
                    };

                    const chart = new google.visualization.ColumnChart(document.getElementById('topCoursesChart'));
                    chart.draw(dataTable, options);
                })
                .catch(err => console.error("Помилка завантаження топу курсів:", err));
        }
    </script>
}