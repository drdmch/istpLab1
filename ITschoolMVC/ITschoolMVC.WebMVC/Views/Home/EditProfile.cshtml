@model ITschoolMVC.Domain.Entities.User

@{
    ViewData["Title"] = "Редагування профілю";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm rounded-4 p-4">
                <h2 class="fw-bold mb-4 text-primary">Редагувати профіль</h2>
                
                <form asp-action="EditProfile" method="post">
                    <div class="mb-3">
                        <label class="form-label">Ім'я</label>
                        <input asp-for="FirstName" class="form-control rounded-pill" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Прізвище</label>
                        <input asp-for="LastName" class="form-control rounded-pill" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Про себе</label>
                        <textarea asp-for="About" class="form-control rounded-4" rows="3"></textarea>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Зберегти</button>
                        <a asp-action="Profile" class="btn btn-outline-secondary rounded-pill px-4">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>