@model ITschoolMVC.Domain.Entities.Course

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary p-4 text-white text-center">
                    <h2 class="fw-bold m-0">Новий IT Курс</h2>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create">
                        <div class="form-floating mb-3">
                            <input asp-for="Title" class="form-control border-0 bg-light" placeholder="Назва" />
                            <label asp-for="Title"></label>
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="LevelId" class="form-label fw-bold">Рівень складності</label>
                            <select asp-for="LevelId" class="form-select rounded-pill shadow-sm" asp-items="ViewBag.LevelId">
                                <option value="">-- Оберіть рівень --</option>
                            </select>
                            <span asp-validation-for="LevelId" class="text-danger small"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Price" type="number" min="0" step="1" class="form-control border-0 bg-light" placeholder="Ціна" />
                            <label asp-for="Price"></label>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <textarea asp-for="Description" class="form-control border-0 bg-light" style="height: 120px" placeholder="Опис"></textarea>
                            <label asp-for="Description"></label>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow">Зберегти</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 rounded-pill">Назад</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>