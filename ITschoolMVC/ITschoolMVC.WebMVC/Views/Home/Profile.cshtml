@model ITschoolMVC.Domain.Entities.User

@{
    ViewData["Title"] = "Мій профіль";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="p-4 bg-primary text-white text-center">
                    <div class="display-1 mb-3"><i class="bi bi-person-circle"></i></div>
                    <h3 class="fw-bold m-0">@Model.FullName</h3>
                    <p class="opacity-75 m-0">@Model.Role?.Name</p>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-1 small">Email</p>
                    <p class="fw-bold">@Model.Email</p>
                    <hr>
                    <p class="text-muted mb-1 small">Про себе</p>
                    <p>@(Model.About ?? "Інформація відсутня")</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h4 class="fw-bold mb-4">Мої права</h4>
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.Role?.Permission != null)
                    {
                        @foreach (var perm in Model.Role.Permission.Split(','))
                        {
                            <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                <i class="bi bi-shield-check text-success me-1"></i> @perm.Trim()
                            </span>
                        }
                    }
                </div>
            </div>

            <div class="mt-3">
                <a asp-action="EditProfile" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                    <i class="bi bi-pencil-square me-1"></i> Редагувати профіль
                </a>
            </div>
        </div>
    </div>
</div>
