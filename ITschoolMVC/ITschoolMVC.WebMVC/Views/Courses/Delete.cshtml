@model ITschoolMVC.Domain.Entities.Course

@{
    ViewData["Title"] = "Видалення курсу";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden ultra-shadow">
                <div class="p-4 text-white text-center" style="background: linear-gradient(135deg, #dc3545, #b02a37) !important;">
                    <i class="bi bi-exclamation-octagon display-4 mb-2"></i>
                    <h2 class="fw-bold m-0">Видалення курсу</h2>
                </div>

                <div class="card-body p-5 text-center">
                    <p class="fs-5 text-muted mb-4">
                        Ви справді хочете видалити курс <br>
                        <strong class="text-dark">"@Model.Title"</strong>?
                    </p>
                    
                    <div class="alert alert-warning border-0 rounded-3 mb-4 small">
                        <i class="bi bi-info-circle me-2"></i>
                        Разом з курсом будуть видалені всі пов'язані уроки та дані. Цю дію неможливо скасувати.
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow-sm fw-bold">
                                <i class="bi bi-trash3 me-2"></i>Підтвердити видалення
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill text-muted">
                                Скасувати
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
